generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  commercial
  livreur
}

enum Unit {
  kg
  g
  l
  ml
  piece
}

enum InvoiceStatus {
  imported
  validated
  rejected
}

enum OrderStatus {
  draft
  validated
  sent
  delivered
  cancelled
}

enum DeliveryStatus {
  pending
  signed
  sent_to_odoo
}

enum CreditNoteStatus {
  draft
  validated
  sent_to_odoo
}

enum PhotoType {
  returned_products
  return_slip
}

enum TraceabilityStep {
  reception
  production
  packaging
  delivery
}

enum BackupStatus {
  success
  failed
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  passwordHash  String
  fullName      String
  role          Role
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  refreshTokens RefreshToken[]
  productions   ProductionBatch[]
  haccpTasks    HaccpTaskEntry[]
  orders        Order[]            @relation("OrderCreatedBy")
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Supplier {
  id         String           @id @default(cuid())
  name       String
  email      String?
  phone      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  invoices   SupplierInvoice[]
  lots       IngredientLot[]
}

model Ingredient {
  id           String         @id @default(cuid())
  name         String
  defaultUnit  Unit
  currentStock Decimal        @default(0) @db.Decimal(12, 3)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lots         IngredientLot[]
  recipeItems  RecipeItem[]

  @@unique([name, defaultUnit])
}

model SupplierInvoice {
  id            String          @id @default(cuid())
  supplierId    String
  invoiceNumber String?
  invoiceDate   DateTime?
  totalAmount   Decimal?        @db.Decimal(12, 2)
  pdfUrl        String
  ocrRawText    String?
  ocrJson       Json?
  status        InvoiceStatus   @default(imported)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  supplier      Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  lots          IngredientLot[]
}

model IngredientLot {
  id                 String            @id @default(cuid())
  ingredientId       String
  supplierId         String
  supplierInvoiceId  String?
  supplierLotRef     String?
  internalLotCode    String            @unique
  receptionDate      DateTime
  expirationDate     DateTime?
  receivedQty        Decimal           @db.Decimal(12, 3)
  remainingQty       Decimal           @db.Decimal(12, 3)
  unitPrice          Decimal?          @db.Decimal(12, 3)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  ingredient         Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  supplier           Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierInvoice    SupplierInvoice?  @relation(fields: [supplierInvoiceId], references: [id], onDelete: SetNull)
  analyses           LabAnalysis[]
  usages             ProductionUsage[]
  traceabilityEvents TraceabilityEvent[]
}

model LabAnalysis {
  id              String         @id @default(cuid())
  ingredientLotId String
  sourceEmail     String
  attachmentUrl   String
  resultJson      Json?
  receivedAt      DateTime
  createdAt       DateTime       @default(now())
  lot             IngredientLot  @relation(fields: [ingredientLotId], references: [id], onDelete: Cascade)
}

model Recipe {
  id           String       @id @default(cuid())
  productName  String       @unique
  instructions String
  casingType   String?
  seasoning    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  items        RecipeItem[]
  productions  ProductionBatch[]
}

model RecipeItem {
  id             String      @id @default(cuid())
  recipeId       String
  ingredientId   String
  quantityPerKg  Decimal     @db.Decimal(12, 3)
  position       Int         @default(0)
  recipe         Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient     Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@unique([recipeId, ingredientId])
}

model ProductionBatch {
  id               String                 @id @default(cuid())
  lotNumber        String                 @unique
  recipeId         String
  productName      String
  producedQtyKg    Decimal                @db.Decimal(12, 3)
  soldQtyKg        Decimal                @default(0) @db.Decimal(12, 3)
  receptionWeek    Int
  receptionYear2   Int
  productionDay    Int
  productionWeek   Int
  startedAt        DateTime               @default(now())
  endedAt          DateTime?
  operatorId       String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  recipe           Recipe                 @relation(fields: [recipeId], references: [id], onDelete: Restrict)
  operator         User                   @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  usages           ProductionUsage[]
  journalEntries   ProductionJournalEntry[]
  outputs          BatchOutput[]
  shrinkageStat    ShrinkageStat?
  traceabilityEvents TraceabilityEvent[]
}

model ProductionUsage {
  id               String          @id @default(cuid())
  productionBatchId String
  ingredientLotId  String
  quantityUsed     Decimal         @db.Decimal(12, 3)
  unit             Unit
  usedAt           DateTime        @default(now())
  productionBatch  ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  ingredientLot    IngredientLot   @relation(fields: [ingredientLotId], references: [id], onDelete: Restrict)
}

model ProductionJournalEntry {
  id               String          @id @default(cuid())
  productionBatchId String
  action           String
  details          String?
  createdAt        DateTime        @default(now())
  productionBatch  ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
}

model BatchOutput {
  id               String          @id @default(cuid())
  productionBatchId String
  outputDate       DateTime
  clientName       String
  quantityKg       Decimal         @db.Decimal(12, 3)
  productionBatch  ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
}

model ShrinkageStat {
  id                String          @id @default(cuid())
  productionBatchId String          @unique
  producedQtyKg     Decimal         @db.Decimal(12, 3)
  soldQtyKg         Decimal         @db.Decimal(12, 3)
  shrinkagePercent  Decimal         @db.Decimal(6, 3)
  computedAt        DateTime        @default(now())
  productionBatch   ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
}

model Client {
  id               String         @id @default(cuid())
  odooClientId     String         @unique
  code             String?
  name             String
  entity           String?
  email            String?
  cadencierJson    Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  orders           Order[]
  deliveryNotes    DeliveryNote[]
  creditNotes      CreditNote[]
}

model Order {
  id               String      @id @default(cuid())
  odooOrderId      String?     @unique
  clientId         String
  createdById      String
  orderDate        DateTime    @default(now())
  status           OrderStatus  @default(draft)
  globalDiscount   Decimal?     @db.Decimal(6, 2)
  note             String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy        User         @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines            OrderLine[]
  deliveryNotes    DeliveryNote[]
}

model OrderLine {
  id              String    @id @default(cuid())
  orderId         String
  productName     String
  quantity        Decimal   @db.Decimal(12, 3)
  unitPrice       Decimal?  @db.Decimal(12, 2)
  lineDiscount    Decimal?  @db.Decimal(6, 2)
  note            String?
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model DeliveryNote {
  id                String           @id @default(cuid())
  odooDeliveryId    String?          @unique
  orderId           String?
  clientId          String
  status            DeliveryStatus   @default(pending)
  sourcePdfUrl      String?
  signedPdfUrl      String?
  signedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  order             Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  signatureCapture  DeliverySignature?
}

model DeliverySignature {
  id                String       @id @default(cuid())
  deliveryNoteId    String       @unique
  customerFirstName String
  signatureDataUrl  String
  selfieDataUrl     String
  latitude          Float
  longitude         Float
  signedAt          DateTime
  deliveryNote      DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
}

model CreditNote {
  id               String           @id @default(cuid())
  odooCreditId     String?          @unique
  clientId         String
  status           CreditNoteStatus @default(draft)
  note             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  client           Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lines            CreditNoteLine[]
  photos           CreditNotePhoto[]
}

model CreditNoteLine {
  id             String      @id @default(cuid())
  creditNoteId   String
  productName    String
  quantity       Decimal     @db.Decimal(12, 3)
  reason         String?
  creditNote     CreditNote  @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
}

model CreditNotePhoto {
  id             String      @id @default(cuid())
  creditNoteId   String
  type           PhotoType
  fileUrl        String
  uploadedAt     DateTime    @default(now())
  creditNote     CreditNote  @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
}

model HaccpChecklist {
  id           String          @id @default(cuid())
  checklistDate DateTime
  zone         String
  createdAt    DateTime        @default(now())
  tasks        HaccpTaskEntry[]
}

model HaccpTaskEntry {
  id                String          @id @default(cuid())
  checklistId       String
  taskLabel         String
  isDone            Boolean         @default(false)
  nonConformity     Boolean         @default(false)
  nonConformityNote String?
  signedAt          DateTime?
  operatorId        String
  checklist         HaccpChecklist  @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  operator          User            @relation(fields: [operatorId], references: [id], onDelete: Restrict)
}

model TraceabilityEvent {
  id                String           @id @default(cuid())
  step              TraceabilityStep
  eventDate         DateTime         @default(now())
  productName       String?
  lotCode           String?
  ingredientLotId   String?
  productionBatchId String?
  clientName        String?
  metadata          Json?
  ingredientLot     IngredientLot?   @relation(fields: [ingredientLotId], references: [id], onDelete: SetNull)
  productionBatch   ProductionBatch? @relation(fields: [productionBatchId], references: [id], onDelete: SetNull)
}

model BackupLog {
  id            String       @id @default(cuid())
  startedAt     DateTime     @default(now())
  finishedAt    DateTime?
  status        BackupStatus
  fileName      String?
  driveFileId   String?
  message       String?
}
