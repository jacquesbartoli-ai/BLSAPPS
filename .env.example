# Shared
NODE_ENV=development

# Secret path to hide app from public, without leading slash
APP_SECRET_PATH=espace-bartoli-xxxxx
APP_ORIGIN=http://localhost:5173
VITE_SECRET_PATH=espace-bartoli-xxxxx
VITE_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/charcuterie

# Google Drive backups
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_OCR_SAMPLE_FOLDER_ID=
# Option A - service account (recommandé pour les backups cron)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Option B - OAuth client + refresh token
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_ACCESS_TOKEN=

# Google Vision OCR
GOOGLE_VISION_API_KEY=

# Odoo
ODOO_BASE_URL=
ODOO_DATABASE=
ODOO_API_KEY=
ODOO_USERNAME=
ODOO_USER_ID=

# Mailbox for analyses
ANALYSES_IMAP_HOST=
ANALYSES_IMAP_PORT=993
ANALYSES_IMAP_USER=analysesbartoli@gmail.com
ANALYSES_IMAP_PASSWORD=
