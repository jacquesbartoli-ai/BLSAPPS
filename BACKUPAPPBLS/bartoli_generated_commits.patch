+generator client {
+  provider = "prisma-client-js"
+}
+
+datasource db {
+  provider = "postgresql"
+  url      = env("DATABASE_URL")
+}
+
+enum Role {
+  admin
+  commercial
+  livreur
+}
+
+enum Unit {
+  kg
+  g
+  l
+  ml
+  piece
+}
+
+enum InvoiceStatus {
+  imported
+  validated
+  rejected
+}
+
+enum OrderStatus {
+  draft
+  validated
+  sent
+  delivered
+  cancelled
+}
+
+enum DeliveryStatus {
+  pending
+  signed
+  sent_to_odoo
+}
+
+enum CreditNoteStatus {
+  draft
+  validated
+  sent_to_odoo
+}
+
+enum PhotoType {
+  returned_products
+  return_slip
+}
+
+enum TraceabilityStep {
+  reception
+  production
+  packaging
+  delivery
+}
+
+enum BackupStatus {
+  success
+  failed
+}
+
+model User {
+  id            String             @id @default(cuid())
+  email         String             @unique
+  passwordHash  String
+  fullName      String
+  role          Role
+  isActive      Boolean            @default(true)
+  createdAt     DateTime           @default(now())
+  updatedAt     DateTime           @updatedAt
+  refreshTokens RefreshToken[]
+  productions   ProductionBatch[]
+  haccpTasks    HaccpTaskEntry[]
+  orders        Order[]            @relation("OrderCreatedBy")
+}
+
+model RefreshToken {
+  id         String   @id @default(cuid())
+  tokenHash  String   @unique
+  userId     String
+  expiresAt  DateTime
+  revokedAt  DateTime?
+  createdAt  DateTime @default(now())
+  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
+}
+
+model AppSetting {
+  id        String   @id @default(cuid())
+  key       String   @unique
+  value     String
+  updatedAt DateTime @updatedAt
+}
+
+model Supplier {
+  id         String           @id @default(cuid())
+  name       String
+  email      String?
+  phone      String?
+  createdAt  DateTime         @default(now())
+  updatedAt  DateTime         @updatedAt
+  invoices   SupplierInvoice[]
+  lots       IngredientLot[]
+}
+
+model Ingredient {
+  id           String         @id @default(cuid())
+  name         String
+  defaultUnit  Unit
+  currentStock Decimal        @default(0) @db.Decimal(12, 3)
+  createdAt    DateTime       @default(now())
+  updatedAt    DateTime       @updatedAt
+  lots         IngredientLot[]
+  recipeItems  RecipeItem[]
+
+  @@unique([name, defaultUnit])
+}
+
+model SupplierInvoice {
+  id            String          @id @default(cuid())
+  supplierId    String
+  invoiceNumber String?
+  invoiceDate   DateTime?
+  totalAmount   Decimal?        @db.Decimal(12, 2)
+  pdfUrl        String
+  ocrRawText    String?
+  ocrJson       Json?
+  status        InvoiceStatus   @default(imported)
+  createdAt     DateTime        @default(now())
+  updatedAt     DateTime        @updatedAt
+  supplier      Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
+  lots          IngredientLot[]
+}
+
+model IngredientLot {
+  id                 String            @id @default(cuid())
+  ingredientId       String
+  supplierId         String
+  supplierInvoiceId  String?
+  supplierLotRef     String?
+  internalLotCode    String            @unique
+  receptionDate      DateTime
+  expirationDate     DateTime?
+  receivedQty        Decimal           @db.Decimal(12, 3)
+  remainingQty       Decimal           @db.Decimal(12, 3)
+  unitPrice          Decimal?          @db.Decimal(12, 3)
+  createdAt          DateTime          @default(now())
+  updatedAt          DateTime          @updatedAt
+  ingredient         Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
+  supplier           Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
+  supplierInvoice    SupplierInvoice?  @relation(fields: [supplierInvoiceId], references: [id], onDelete: SetNull)
+  analyses           LabAnalysis[]
+  usages             ProductionUsage[]
+  traceabilityEvents TraceabilityEvent[]
+}
+
+model LabAnalysis {
+  id              String         @id @default(cuid())
+  ingredientLotId String
+  sourceEmail     String
+  attachmentUrl   String
+  resultJson      Json?
+  receivedAt      DateTime
+  createdAt       DateTime       @default(now())
+  lot             IngredientLot  @relation(fields: [ingredientLotId], references: [id], onDelete: Cascade)
+}
+
+model Recipe {
+  id           String       @id @default(cuid())
+  productName  String       @unique
+  instructions String
+  casingType   String?
+  seasoning    String?
+  createdAt    DateTime     @default(now())
+  updatedAt    DateTime     @updatedAt
+  items        RecipeItem[]
+  productions  ProductionBatch[]
+}
+
+model RecipeItem {
+  id             String      @id @default(cuid())
+  recipeId       String
+  ingredientId   String
+  quantityPerKg  Decimal     @db.Decimal(12, 3)
+  position       Int         @default(0)
+  recipe         Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
+  ingredient     Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
+
+  @@unique([recipeId, ingredientId])
+}
+
+model ProductionBatch {
+  id               String                 @id @default(cuid())
+  lotNumber        String                 @unique
+  recipeId         String
+  productName      String
+  producedQtyKg    Decimal                @db.Decimal(12, 3)
+  soldQtyKg        Decimal                @default(0) @db.Decimal(12, 3)
+  receptionWeek    Int
+  receptionYear2   Int
+  productionDay    Int
+  productionWeek   Int
+  startedAt        DateTime               @default(now())
+  endedAt          DateTime?
+  operatorId       String
+  createdAt        DateTime               @default(now())
+  updatedAt        DateTime               @updatedAt
+  recipe           Recipe                 @relation(fields: [recipeId], references: [id], onDelete: Restrict)
+  operator         User                   @relation(fields: [operatorId], references: [id], onDelete: Restrict)
+  usages           ProductionUsage[]
+  journalEntries   ProductionJournalEntry[]
+  outputs          BatchOutput[]
+  shrinkageStat    ShrinkageStat?
+  traceabilityEvents TraceabilityEvent[]
+}
+
+model ProductionUsage {
+  id               String          @id @default(cuid())
+  productionBatchId String
+  ingredientLotId  String
+  quantityUsed     Decimal         @db.Decimal(12, 3)
+  unit             Unit
+  usedAt           DateTime        @default(now())
+  productionBatch  ProductionBatch @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
+  ingredientLot    IngredientLot   @relation(fields: [ingredientLotId], references: [id], onDelete: Restrict)
+}
+
+model ProductionJournalEntry {
+  id               String          @id @default(cuid())
+  productionBatchId String
+  action           String
+  details          String?
+  createdAt        DateTime        @default(now())
